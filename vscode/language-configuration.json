{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "#\"", "close": "\"#", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^(think|screen|piece|box|words|tap|field|image|serve|database|task|queue|live|auth|routes|when|each|transaction|hover|enter|leave|press|animate|gesture|pan)\\b.*$",
    "decreaseIndentPattern": "^\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^(  )*(think|screen|piece|box|words|tap|field|image|serve|database|task|queue|live|auth|routes|when|each)\\b",
      "action": {
        "indent": "indent"
      }
    }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(think|screen|piece|box|words|tap|serve|database|task|queue|live)\\b",
      "end": "^\\s*$"
    }
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*"
}
