{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VED",
  "scopeName": "source.ved",
  "fileTypes": ["ved"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#colors" },
    { "include": "#booleans" },
    { "include": "#keywords-control" },
    { "include": "#keywords-ui" },
    { "include": "#keywords-server" },
    { "include": "#keywords-shared" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.ved",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ved",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ved",
              "match": "\\\\[nrt\"\\\\]"
            },
            {
              "name": "meta.interpolation.ved",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.template-expression.begin.ved" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.template-expression.end.ved" }
              },
              "patterns": [
                { "include": "#expressions" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.raw.ved",
          "begin": "#\"",
          "end": "\"#",
          "patterns": []
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ved",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.ved",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.numeric.percentage.ved",
          "match": "\\b[0-9]+%"
        },
        {
          "name": "constant.numeric.time.ved",
          "match": "\\b[0-9]+(ms|s|h)\\b"
        }
      ]
    },
    "colors": {
      "patterns": [
        {
          "name": "constant.other.color.ved",
          "match": "#[0-9a-fA-F]{3,8}\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.ved",
          "match": "\\b(yes|no|nothing)\\b"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.ved",
          "match": "\\b(when|otherwise|each|in|give|fail|try|wait|go|back|and|or|not|is|with|as|mut|async)\\b"
        }
      ]
    },
    "keywords-ui": {
      "patterns": [
        {
          "name": "keyword.other.ui.ved",
          "match": "\\b(screen|piece|box|words|tap|field|image|routes|remember|fetch|show|hide|ghost)\\b"
        },
        {
          "name": "keyword.other.ui-prop.ved",
          "match": "\\b(fill|tall|flow|gap|padding|center|radius|border|shadow|blur|opacity|scroll|clip|cursor|layer|push|size|weight|align|spacing|lines|cut|color|backdrop|lazy|stream|sync|presence|transform|snap|direction|velocity|threshold)\\b"
        },
        {
          "name": "keyword.other.animation.ved",
          "match": "\\b(hover|enter|leave|press|animate|gesture|pan|spring|ease|duration|stiffness|damping|mass|from|to|physics)\\b"
        },
        {
          "name": "keyword.other.event.ved",
          "match": "\\b(on|load|key|connect|message|broadcast)\\b"
        }
      ]
    },
    "keywords-server": {
      "patterns": [
        {
          "name": "keyword.other.server.ved",
          "match": "\\b(serve|database|task|queue|live|auth|transaction|every|at|workers|retry|guard|confirm|reply|route)\\b"
        },
        {
          "name": "keyword.other.server-prop.ved",
          "match": "\\b(port|prefix|secret|expires|kind|url|pool|path)\\b"
        },
        {
          "name": "keyword.other.db.ved",
          "match": "\\b(db)\\b"
        },
        {
          "name": "keyword.other.http.ved",
          "match": "\\b(GET|POST|PUT|PATCH|DEL)\\b"
        }
      ]
    },
    "keywords-shared": {
      "patterns": [
        {
          "name": "keyword.declaration.ved",
          "match": "\\b(think|let|shape|load|connect|param|needs)\\b"
        },
        {
          "name": "keyword.other.cache.ved",
          "match": "\\b(cache|loading|error|ok|maybe)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.ved",
          "match": "\\b(num|dec|text|bool|list|map|any|fn)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.ved",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.fat-arrow.ved",
          "match": "=>"
        },
        {
          "name": "keyword.operator.thin-arrow.ved",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.ved",
          "match": "(!=|==|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.ved",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.ved",
          "match": "[+\\-*/%]"
        },
        {
          "name": "punctuation.separator.colon.ved",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.ved",
          "match": ","
        },
        {
          "name": "punctuation.terminator.dot.ved",
          "match": "\\."
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.ved",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\s*(?=\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.ved",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b"
        }
      ]
    },
    "expressions": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#operators" },
        { "include": "#identifiers" }
      ]
    }
  }
}
